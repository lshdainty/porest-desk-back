# Database
DB_URL=jdbc:mariadb://localhost:3306/porest_desk
DB_USERNAME=your_username
DB_PASSWORD=your_password

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
REDIS_DATABASE=3

# Server
SERVER_PORT=8002

# JWT
JWT_SECRET=your-jwt-secret-key-must-be-at-least-256-bits-long-for-hs256
JWT_SSO_SECRET=your-sso-secret-key-must-be-at-least-256-bits-long-for-hs256

# SSO
SSO_API_URL=http://localhost:8001

# CORS
CORS_ORIGINS=http://localhost:3002

# Logging (info / debug / trace / warn / error)
LOG_LEVEL=info
LOG_LEVEL_HIBERNATE=info
LOG_LEVEL_ROOT=info

# P6Spy (true / false)
P6SPY_ENABLED=true

# Swagger (true / false)
SWAGGER_ENABLED=true

# Error Display (always / never)
ERROR_STACKTRACE=never
ERROR_MESSAGE=never
ERROR_EXCEPTION=false
ERROR_BINDING=never
